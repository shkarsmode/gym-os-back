DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gymos?schema=public"
# Direct (unpooled) connection — REQUIRED in every environment that runs schema changes.
# schema.prisma declares this as `directUrl`. Neon's pooled endpoint (pgbouncer in
# transaction mode) cannot take the advisory locks `prisma migrate` / `db push` need,
# so with this unset schema changes fail — and because scripts/vercel-build.mjs runs
# them non-fatally, they fail SILENTLY. That is why several tables are patched at
# runtime with CREATE TABLE IF NOT EXISTS instead of by a migration.
# On Neon this is the same host with "-pooler" removed from the hostname.
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/gymos?schema=public"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"
JWT_SECRET="replace-with-a-long-random-secret"
FRONTEND_URL="http://localhost:8080"
ADMIN_EMAILS="you@example.com"
DEMO_OWNER_EMAIL="you@example.com"
ALLOW_FILE_ORIGIN="false"
# Runs `prisma db push` during postinstall. Legacy escape hatch for local/throwaway
# databases only. `db push` and `prisma migrate` are mutually exclusive workflows: a
# push against a migrated database drifts it away from the migration history without
# recording anything. Never enable this together with GYMOS_MIGRATE_ON_DEPLOY.
GYMOS_AUTO_DB_PUSH="false"

# Runs `prisma migrate deploy` during postinstall — which is the ONLY build hook Vercel
# actually executes, because vercel.json uses a legacy `builds` array and Vercel then
# ignores buildCommand entirely.
#   unset/empty  migrations do not run (default)
#   warn         migrations run; a failure logs but does not fail the build
#   strict       migrations run; a failure fails the build
# Production must be baselined ONCE before enabling either mode:
#   prisma migrate resolve --applied 0_init
# Otherwise migrate deploy tries to apply the baseline to a database that already has
# every table. Go through "warn" for at least two green deploys before "strict".
GYMOS_MIGRATE_ON_DEPLOY=""
NODE_ENV="development"

# --- AI (Gemini) workout parsing — admin-only feature ---
# Create a free API key in Google AI Studio (https://aistudio.google.com/apikey) for a
# project named "GymOS". Set it ONLY here in the backend environment — never commit it.
GEMINI_API_KEY=""
# Free-tier model good for fast structured output. Leave empty to use the default
# (gemini-3.1-flash-lite). Note: gemini-2.5-flash was retired for new API keys.
# Alternatives: gemini-2.5-flash-lite (higher documented daily quota) or gemini-3.5-flash.
GEMINI_MODEL=""
# Hard timeout for a single Gemini call (milliseconds).
GEMINI_REQUEST_TIMEOUT_MS="15000"
# Maximum length of the user's workout description sent to Gemini.
GEMINI_MAX_INPUT_LENGTH="6000"
