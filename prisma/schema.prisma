generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    // Direct (unpooled) connection for migrations / db push — Neon's pooled URL
    // (pgbouncer) can't run the DDL, which left the ExerciseReaction table uncreated.
    // Runtime still uses the pooled `url`; directUrl is only used by Prisma CLI.
    directUrl = env("DATABASE_URL_UNPOOLED")
}

enum WorkoutStatus {
    planned
    active
    completed
}

enum WorkoutSetType {
    warmup
    working
    drop
    failure
    backoff
}

model User {
    id                 String                    @id @default(cuid())
    email              String                    @unique
    googleId           String?                   @unique
    displayName        String
    avatarUrl          String?
    approved           Boolean                   @default(false)
    role               String                    @default("free")
    preferences        Json?
    createdAt          DateTime                  @default(now())
    updatedAt          DateTime                  @updatedAt
    oauthAccounts      OAuthAccount[]
    profile            UserProfile?
    bodyweightEntries  UserBodyweightEntry[]
    exercises          Exercise[]                @relation("CustomExercises")
    workouts           Workout[]
    personalRecords    PersonalRecord[]
    achievements       UserAchievement[]
    workoutTemplates   WorkoutTemplate[]
    exerciseReactions  ExerciseReaction[]
    featureRequests    FeatureRequest[]
}

model OAuthAccount {
    id                String    @id @default(cuid())
    userId            String
    provider          String
    providerAccountId String
    accessToken       String?
    refreshToken      String?
    expiresAt         DateTime?
    createdAt         DateTime  @default(now())
    updatedAt         DateTime  @updatedAt
    user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
    @@index([userId])
}

model UserProfile {
    id                  String   @id @default(cuid())
    userId              String   @unique
    name                String
    displayName         String
    height              Int?
    bodyweight          Decimal? @db.Decimal(6, 2)
    gender              String   @default("male")
    trainingGoal        String?
    trainingExperience  String?
    favoriteMuscleGroup String?
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt
    user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserBodyweightEntry {
    id          String   @id @default(cuid())
    userId      String
    date        DateTime
    bodyweight  Decimal  @db.Decimal(6, 2)
    notes       String?
    createdAt   DateTime @default(now())
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([userId, date])
}

model Exercise {
    id                    String                    @id @default(cuid())
    slug                  String                    @unique
    name                  String
    aliases               Json                      @default("[]")
    primaryMuscleGroup    String
    secondaryMuscleGroups Json                      @default("[]")
    movementPattern       String
    equipment             String
    category              String
    difficulty            String
    description           String?
    techniqueSteps        Json                      @default("[]")
    commonMistakes        Json                      @default("[]")
    safetyTips            Json                      @default("[]")
    mediaUrl              String?
    mediaType             String                    @default("none")
    sourceName            String?
    sourceUrl             String?
    originalName          String?
    licenseStatus         String?
    mediaReferences       Json                      @default("[]")
    sourceImportedAt      DateTime?
    isCustom              Boolean                   @default(false)
    status                String                    @default("approved")
    createdByUserId       String?
    createdAt             DateTime                  @default(now())
    updatedAt             DateTime                  @updatedAt
    createdByUser         User?                     @relation("CustomExercises", fields: [createdByUserId], references: [id], onDelete: SetNull)
    workoutExercises      WorkoutExercise[]
    personalRecords       PersonalRecord[]
    strengthStandards     StrengthStandard[]
    templateExercises     WorkoutTemplateExercise[]
    reactions             ExerciseReaction[]

    @@index([isCustom])
    @@index([createdByUserId])
    @@index([status])
}

model ExerciseReaction {
    id         String   @id @default(cuid())
    exerciseId String
    userId     String
    type       String // "like" | "dislike"
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
    exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([exerciseId, userId])
    @@index([exerciseId])
    @@index([userId])
}

model FeatureRequest {
    id          String   @id @default(cuid())
    userId      String
    type        String // "feature" | "fix" | "improvement"
    title       String
    description String?
    status      String   @default("new") // "new" | "planned" | "in_progress" | "done" | "declined"
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([status])
}

model Workout {
    id              String            @id @default(cuid())
    userId          String
    date            DateTime
    title           String
    status          WorkoutStatus     @default(planned)
    workoutType     String
    startedAt        DateTime?
    finishedAt       DateTime?
    durationOverride Int?
    notes            String?
    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @updatedAt
    user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
    exercises       WorkoutExercise[]
    cardioSessions  CardioSession[]
    personalRecords PersonalRecord[]

    @@index([userId])
    @@index([userId, status])
    @@index([userId, date])
}

model WorkoutExercise {
    id         String       @id @default(cuid())
    workoutId  String
    exerciseId String
    order      Int
    notes      String?
    createdAt  DateTime     @default(now())
    updatedAt  DateTime     @updatedAt
    workout    Workout      @relation(fields: [workoutId], references: [id], onDelete: Cascade)
    exercise   Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
    sets       WorkoutSet[]

    @@index([workoutId])
    @@index([exerciseId])
}

model WorkoutSet {
    id                String          @id @default(cuid())
    workoutExerciseId String
    type              WorkoutSetType  @default(working)
    weight            Decimal         @default(0) @db.Decimal(7, 2)
    repetitions       Int             @default(0)
    // Optional timed-set duration in seconds (planks, static holds, timed carries).
    // NULL for classic rep-based sets and every pre-existing row — never backfilled.
    durationSeconds   Int?
    rpe               Decimal?        @db.Decimal(4, 1)
    restSeconds       Int             @default(90)
    isCompleted       Boolean         @default(false)
    notes             String?
    createdAt         DateTime        @default(now())
    updatedAt         DateTime        @updatedAt
    workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

    @@index([workoutExerciseId])
}

model CardioSession {
    id                String   @id @default(cuid())
    workoutId         String
    type              String
    durationMinutes   Int
    distance          Decimal? @db.Decimal(7, 2)
    calories          Int?
    averageHeartRate  Int?
    intensity         String?
    notes             String?
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
    workout           Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

    @@index([workoutId])
}

model PersonalRecord {
    id                  String   @id @default(cuid())
    userId              String
    exerciseId          String
    workoutId           String?
    type                String
    value               Decimal  @db.Decimal(8, 2)
    estimatedOneRepMax  Decimal? @db.Decimal(8, 2)
    weight              Decimal? @db.Decimal(7, 2)
    repetitions         Int?
    isEstimated         Boolean  @default(true)
    recordedAt          DateTime @default(now())
    user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    exercise            Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
    workout             Workout? @relation(fields: [workoutId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([exerciseId])
    @@index([workoutId])
}

model Achievement {
    id               String            @id @default(cuid())
    key              String            @unique
    title            String
    description      String
    category         String
    target           Int
    metric           String
    createdAt        DateTime          @default(now())
    userAchievements UserAchievement[]
}

model UserAchievement {
    id            String      @id @default(cuid())
    userId        String
    achievementId String
    progress      Int         @default(0)
    unlockedAt    DateTime?
    createdAt     DateTime    @default(now())
    updatedAt     DateTime    @updatedAt
    user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

    @@unique([userId, achievementId])
}

model StrengthStandard {
    id              String   @id @default(cuid())
    exerciseId      String
    gender          String
    bodyweightMin   Decimal  @db.Decimal(6, 2)
    bodyweightMax   Decimal  @db.Decimal(6, 2)
    level           String
    requiredWeight  Decimal  @db.Decimal(7, 2)
    repetitions     Int      @default(1)
    sourceName      String
    sourceNote      String?
    isOfficial      Boolean  @default(false)
    updatedAt       DateTime @updatedAt
    exercise        Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

    @@index([exerciseId])
}

model WorkoutTemplate {
    id          String                    @id @default(cuid())
    userId      String?
    title       String
    description String?
    type        String
    isPublic    Boolean                   @default(true)
    createdAt   DateTime                  @default(now())
    updatedAt   DateTime                  @updatedAt
    user        User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
    exercises   WorkoutTemplateExercise[]

    @@index([userId])
}

model WorkoutTemplateExercise {
    id                String          @id @default(cuid())
    workoutTemplateId String
    exerciseId        String
    order             Int
    targetSets        Int?
    targetReps        Int?
    restSeconds       Int?
    notes             String?
    workoutTemplate   WorkoutTemplate @relation(fields: [workoutTemplateId], references: [id], onDelete: Cascade)
    exercise          Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

    @@index([workoutTemplateId])
    @@index([exerciseId])
}

// Audit log for AI (Gemini) calls made by the admin-only AI-workout feature. One row
// per backend call. `userId` is a loose reference (no FK) so the log survives user
// deletion for auditing. Never stores prompts, transcripts, responses, or secrets —
// only safe usage metadata and normalized error codes.
model AiUsageLog {
    id                  String   @id @default(cuid())
    userId              String?
    operation           String
    model               String
    status              String
    errorCode           String?
    errorMessage        String?
    inputTokens         Int?
    outputTokens        Int?
    totalTokens         Int?
    cachedTokens        Int?
    thoughtsTokens      Int?
    durationMs          Int?
    inputLength         Int?
    recognizedExercises Int?
    warningsCount       Int?
    createdAt           DateTime @default(now())

    @@index([createdAt])
    @@index([userId])
    @@index([status])
}
